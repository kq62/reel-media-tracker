# Copy this file to .env for local dev. For production, set these as
# environment variables in your Vercel project dashboard instead —
# never commit .env with real values.

# PostgreSQL connection string.
# Supabase requires TWO connection strings:
#   DATABASE_URL  — Transaction pooler (port 6543) — used by the app at runtime
#   DIRECT_URL    — Direct connection (port 5432) — used by Prisma for queries/migrations
# Both are in Supabase → Project Settings → Database → Connection string
# Railway only needs DATABASE_URL (no DIRECT_URL needed).
DATABASE_URL=""
DIRECT_URL=""

# NextAuth
# Generate with: openssl rand -base64 32
# In Vercel: set NEXTAUTH_SECRET to the same generated value.
# NEXTAUTH_URL: set to your Vercel deployment URL in production
#   (e.g. https://your-app.vercel.app) — Vercel also sets
#   NEXTAUTH_URL automatically via the VERCEL_URL env var, but
#   setting it explicitly avoids edge cases with preview deploys.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# TMDB API — free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=""
